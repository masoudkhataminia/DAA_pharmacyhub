# Runtime only. Do not commit real values.
MYPAK_BASE_URL=https://api.mypak.app/api
# MyPak account login is entered in the protected UI and held only in backend memory.
# These legacy credential fields are intentionally ignored by the portal runtime.
MYPAK_AUTHORIZATION=
MYPAK_USERNAME=
MYPAK_PASSWORD=
MYPAK_LOGIN_URL=
MYPAK_LOGIN_METHOD=
MYPAK_LOGIN_BODY_TEMPLATE=
MYPAK_SYNC_INTERVAL_MINUTES=0
MPS_BASE_URL=https://www.medisphere.mpsconnect.com.au
MPS_BEARER_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://daa.mypharmacyhub.net/api/gmail/callback
# Generate a long random value; used only to encrypt the Gmail refresh token on disk.
GMAIL_TOKEN_KEY=
# Optional legacy migration fallback for the Google account that owns data/store.json.
# New Google accounts do not need this value and always receive separate workspaces.
WORKSPACE_OWNER_EMAIL=
# Generate a separate long random value for signed, HttpOnly login sessions.
APP_SESSION_SECRET=
OPENAI_API_KEY=
OPENAI_DOCTOR_CHANGE_MODEL=gpt-5-mini
OPENAI_SMART_SCRIPT_MODEL=gpt-5-mini
